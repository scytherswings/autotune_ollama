infra:
  ollama_host: localhost
  ollama_port: 11434
  compose_dir: configs
  compose_project: ollama-autotune
  ollama_volume: ollama_ollama

models:
  - llama3.1:8b-instruct-q8_0
  - gemma3:12b
  - qwen3:14b
  - qwen2.5-coder:14b-instruct-q4_K_M
  - deepseek-coder-v2:16b-lite-instruct-q4_K_M

infra_configs:
  - baseline
  - flash-attn

eval:
  types: [coding, tool_call]
  prompts_file: eval_prompts.json
  # How much each type contributes to the blended quality score that coordinate descent optimizes.
  # Tune this to reflect your actual use-case priorities.
  # Must sum to 1.0 across all active types.
  type_weights:
    coding: 0.40
    tool_call: 0.60

search_space:
  num_ctx: [4096, 8192, 16384, 32768]
  temperature: [0.0, 0.1, 0.3]
  top_p: [0.9, 0.95, 1.0]
  top_k: [20, 40, 80]
  repeat_penalty: [1.0, 1.1]
  num_predict: [512, 1024, 2048]

defaults:
  num_ctx: 8192
  temperature: 0.1
  top_p: 0.95
  top_k: 40
  repeat_penalty: 1.0
  num_predict: 1024

scoring:
  quality_weight: 0.65
  speed_weight: 0.25
  ttft_weight: 0.10

judge:
  model: claude-sonnet-4-20250514
  quality_weights:
    # --- Coding sub-scores (must sum to 1.0) ---
    coding_correctness: 0.40
    coding_completeness: 0.30
    coding_clarity: 0.20
    coding_agent_utility: 0.10

    # --- Tool-call blend: objective checks vs. Claude judge (must sum to 1.0) ---
    objective_weight: 0.50   # deterministic: JSON valid, correct tool chosen, required args present
    judge_weight: 0.50       # semantic: Claude scores arg values and tool selection

    # --- Tool-call semantic sub-scores (must sum to 1.0) ---
    tool_arg_correctness: 0.60  # were argument values right given the user's request?
    tool_selection: 0.40        # was the correct tool (or no tool) chosen?

budget:
  max_api_calls: 10000
  min_tokens_per_sec: 20
