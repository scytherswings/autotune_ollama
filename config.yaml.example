infra:
  ollama_host: localhost
  ollama_port: 11434
  compose_dir: configs
  compose_project: ollama-autotune
  ollama_volume: ollama_ollama

# Models that fit in 12GB VRAM. qwen3-coder:30b is listed last as a slow reference point.
models:
  - llama3.1:8b-instruct-q8_0          # Meta tool-use training; fast baseline
  - gemma3:12b                          # strong for size; already pulled
  - qwen3:14b                           # Qwen3 family; already pulled
  - qwen2.5-coder:14b-instruct-q4_K_M  # coding eval winner; tool-calling unknown
  - deepseek-coder-v2:16b-lite-instruct-q4_K_M  # MoE; #2 in coding eval
  - qwen3-coder:30b                     # 17GB — will CPU-offload; slow reference point

# Models to skip entirely — no pull, no eval. Useful for models known to be
# incompatible (e.g. no native tool support) or already eliminated.
# gemma3 and deepseek eliminated: tool_call scores 4.94 / 4.44 — not competitive
# for tool-call use cases. Baseline data preserved in results.tsv for reference.
skip_models:
  - gemma3:12b
  - deepseek-coder-v2:16b-lite-instruct-q4_K_M

infra_configs:
  - baseline
  - flash-attn

eval:
  types: [coding, tool_call, chat]
  prompts_file: eval_prompts.json
  # chat is the primary use case; tool_call secondary; coding as reference signal
  type_weights:
    coding: 0.20
    tool_call: 0.40
    chat: 0.40

# num_ctx includes large values for potential RAG use later; coordinate descent will
# find the best value and the GPU allocation logging will show VRAM impact.
search_space:
  num_ctx: [4096, 8192, 16384, 32768]
  temperature: [0.0, 0.1, 0.3]
  top_p: [0.9, 1.0]
  # num_predict dropped: not a meaningful tuning knob — responses are short for
  # tool_call, and thinking models (qwen3) need uncapped generation budget.
  # top_k dropped: Δ0.07–0.11 across all models, within noise
  # repeat_penalty dropped: no measurable sensitivity in results
  # top_p middle value (0.95) dropped: keep extremes only

defaults:
  num_ctx: 8192
  temperature: 0.1
  top_p: 0.95
  top_k: 40
  repeat_penalty: 1.0
  num_predict: -1  # unlimited — thinking models need uncapped generation budget

scoring:
  quality_weight: 0.65
  latency_weight: 0.35  # total wall-clock time per prompt (includes thinking time)

judge:
  model: claude-sonnet-4-20250514
  quality_weights:
    coding_correctness: 0.40
    coding_completeness: 0.30
    coding_clarity: 0.20
    coding_agent_utility: 0.10

    objective_weight: 0.50
    judge_weight: 0.50

    tool_arg_correctness: 0.60
    tool_selection: 0.40

    chat_instruction_following: 0.25
    chat_content_quality: 0.30
    chat_professionalism: 0.20
    chat_conciseness: 0.15
    chat_context_retention: 0.10

budget:
  max_api_calls: 10000
  min_tokens_per_sec: 20
