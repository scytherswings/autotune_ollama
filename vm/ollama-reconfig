#!/bin/bash
# /home/autotune/bin/ollama-reconfig
# Gatekeeper script: only allows pre-approved Ollama configurations.
# Accepts a config name, maps it to a Docker Compose file, restarts the container.

CONFIGS_DIR="$HOME/ollama-configs"
CONFIG_NAME="$1"

ALLOWED=("baseline" "flash-attn" "parallel-2" "parallel-4" "low-overhead")

if [[ -z "$CONFIG_NAME" ]]; then
    echo "Usage: ollama-reconfig <config-name>"
    echo "Allowed: ${ALLOWED[*]}"
    exit 1
fi

if [[ ! " ${ALLOWED[*]} " =~ " ${CONFIG_NAME} " ]]; then
    echo "ERROR: Unknown config '$CONFIG_NAME'. Allowed: ${ALLOWED[*]}"
    exit 1
fi

COMPOSE_FILE="$CONFIGS_DIR/docker-compose.${CONFIG_NAME}.yml"

if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "ERROR: Compose file not found: $COMPOSE_FILE"
    exit 1
fi

cd "$CONFIGS_DIR" || exit 1
sudo docker compose -f "$COMPOSE_FILE" up -d --force-recreate

echo "Waiting for Ollama API..."
for i in $(seq 1 30); do
    curl -s http://localhost:11434/api/tags > /dev/null 2>&1 && echo "Ready." && exit 0
    sleep 2
done

echo "ERROR: Ollama did not start within 60s"
exit 1
